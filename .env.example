# 阿里云凭证
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_DEFAULT_REGION=cn-hangzhou

# 腾讯云凭证
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_DEFAULT_REGION=ap-guangzhou

# 华为云凭证
HUAWEI_ACCESS_KEY_ID=your_ak
HUAWEI_SECRET_ACCESS_KEY=your_sk
HUAWEI_DEFAULT_REGION=cn-east-3
HUAWEI_PROJECT_ID=your_project_id

# WinRM 默认凭证（也可在 servers.yaml 中按服务器覆盖）
WINRM_DEFAULT_USERNAME=Administrator
WINRM_DEFAULT_PASSWORD=

# SSH 默认私钥路径
SSH_DEFAULT_KEY_PATH=~/.ssh/id_rsa

# 日志级别
LOG_LEVEL=INFO
