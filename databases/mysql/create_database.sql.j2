-- MySQL 建库模板（Jinja2）
CREATE DATABASE IF NOT EXISTS `{{ database_name }}`
  CHARACTER SET utf8mb4
  COLLATE utf8mb4_unicode_ci;

-- 创建应用账号（只有库级别权限，不用 root）
{% if app_username is defined and app_username %}
CREATE USER IF NOT EXISTS '{{ app_username }}'@'%' IDENTIFIED BY '{{ app_password | default("ChangeMe123!") }}';
GRANT SELECT, INSERT, UPDATE, DELETE, CREATE, DROP, INDEX, ALTER ON `{{ database_name }}`.* TO '{{ app_username }}'@'%';
FLUSH PRIVILEGES;
{% endif %}
